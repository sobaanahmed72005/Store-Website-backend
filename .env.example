# Copy to .env and fill in real values. Never commit .env itself.

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Secret-at-rest encryption for stored payment/courier credentials and 2FA secrets.
# Must be a 32-byte hex string — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=

# Server
PORT=5000
FRONTEND_URL=http://localhost:5173

# Optional: override this server's own public URL (used to build absolute links to
# uploaded images/logos in emails). Defaults to http://localhost:<PORT>.
BACKEND_URL=

# Optional: skip hostname-based tenant resolution and always serve this one store slug.
# Only needed for single-store deployments (see middleware/tenant.js).
DEFAULT_STORE_SLUG=

# Optional: override the obfuscated admin panel path (see src/config/adminPath.js).
# Must start with "/", no trailing slash. Obscurity only — not a substitute for auth.
ADMIN_PATH=

# Seeded store admin account (only used if the account doesn't already exist)
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Outgoing email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional: error tracking (https://sentry.io) — get a project's DSN from
# Settings -> Projects -> (project) -> Client Keys (DSN). Leave unset to disable; errors are
# still logged locally either way (see utils/logger.js).
SENTRY_DSN=

# Optional: object storage for uploaded product images and payment-proof screenshots (see
# utils/objectStorage.js). Leave S3_BUCKET unset to keep writing to local disk (./uploads,
# ./payment-proofs) — fine for a single instance, but those files won't be visible to any other
# instance if this app is ever scaled horizontally, so set these before doing that.
#
# Works with any S3-compatible provider. For Cloudflare R2: create a bucket in the dashboard
# (R2 -> Create bucket), then R2 -> Manage API Tokens -> Create API Token for the key pair.
#   S3_ENDPOINT      = https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION         = auto
#   S3_PUBLIC_URL     = the bucket's public URL (R2 -> bucket -> Settings -> Public access), or
#                        your own domain if you've mapped one to the bucket
# For AWS S3 instead: leave S3_ENDPOINT unset, set S3_REGION to your bucket's region, and
# S3_PUBLIC_URL to https://<bucket>.s3.<region>.amazonaws.com (or a CloudFront domain in front of it).
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# Optional: DB connection pool size — see config/db.js. Defaults to 20 if unset; raise for
# higher concurrent traffic, keeping it under your MySQL server's max_connections.
DB_POOL_SIZE=
